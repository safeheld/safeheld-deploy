// ─── MODELS ──────────────────────────────────────────────────────────────────

model Firm {
  id                              String              @id @default(uuid()) @db.Uuid
  name                            String              @db.VarChar(255)
  fcaFrn                          String?             @db.VarChar(20) @map("fca_frn")
  regime                          FirmRegime
  status                          FirmStatus          @default(ONBOARDING)
  baseCurrency                    String              @default("GBP") @db.Char(3) @map("base_currency")
  dateFormat                      DateFormatEnum      @default(DD_MM_YYYY) @map("date_format")
  safeguardingMethod              SafeguardingMethod  @map("safeguarding_method")
  reconciliationDays              Json                @default("[\"MON\",\"TUE\",\"WED\",\"THU\",\"FRI\"]") @map("reconciliation_days")
  includeBankHolidaysAsReconDays  Boolean             @default(false) @map("include_bank_holidays_as_recon_days")
  materialDiscrepancyPct          Decimal?            @db.Decimal(8, 4) @map("material_discrepancy_pct")
  materialDiscrepancyAbs          Decimal?            @db.Decimal(18, 2) @map("material_discrepancy_abs")
  dpaSignedDate                   DateTime?           @db.Date @map("dpa_signed_date")
  dpaSigned                       Boolean             @default(false) @map("dpa_signed")
  createdAt                       DateTime            @default(now()) @map("created_at")
  updatedAt                       DateTime            @updatedAt @map("updated_at")

  // CASS-specific fields
  cassClassification              CassClassification? @map("cass_classification")
  cassAuditDueDate                DateTime?           @db.Date @map("cass_audit_due_date")
  cmarSubmissionFrequency         CmarFrequency?      @map("cmar_submission_frequency")

  users                           User[]
  clientAccounts                  ClientAccount[]
  clientBalances                  ClientBalance[]
  clientTransactions              ClientTransaction[]
  safeguardingAccounts            SafeguardingAccount[]
  safeguardingLedgerBalances      SafeguardingLedgerBalance[]
  bankBalances                    BankBalance[]
  bankTransactions                BankTransaction[]
  uploads                         Upload[]
  mappingConfigs                  MappingConfig[]
  reconciliationRuns              ReconciliationRun[]
  reconciliationBreaks            ReconciliationBreak[]
  breaches                        Breach[]
  fcaNotifications                FcaNotification[]
  assuranceReports                AssuranceReport[]
  acknowledgementLetters          AcknowledgementLetter[]
  responsibilityAssignments       ResponsibilityAssignment[]
  thirdPartyDueDiligence          ThirdPartyDueDiligence[]
  insuranceGuarantees             InsuranceGuarantee[]
  agentsAndDistributors           AgentAndDistributor[]
  policyDocuments                 PolicyDocument[]
  resolutionPackHealths           ResolutionPackHealthCheck[]
  boardReports                    BoardReport[]
  auditLogs                       AuditLog[]
  auditorFindings                 AuditorFinding[]
  systemHealthChecks              SystemHealthCheck[]
  alertSettings                   AlertSetting[]
  emailLogs                       EmailLog[]
  bankInstitutionFirms            BankInstitutionFirm[]
  wallets                         Wallet[]
  walletBalances                  WalletBalance[]
  clientEntitlements              ClientEntitlement[]
  proofOfReserves                 ProofOfReserves[]
  dataLineageEvents               DataLineageEvent[]
  clientAssets                    ClientAsset[]
  cmarSubmissions                 CmarSubmission[]
  riskControls                    RiskControl[]
  regulatoryUpdates               RegulatoryUpdate[]
  impactAssessments               ImpactAssessment[]

  @@map("firms")
}

model User {
  id                String      @id @default(uuid()) @db.Uuid
  firmId            String      @db.Uuid @map("firm_id")
  email             String      @unique @db.VarChar(255)
  passwordHash      String      @db.VarChar(255) @map("password_hash")
  role              UserRole
  name              String      @db.VarChar(255)
  mfaEnabled        Boolean     @default(false) @map("mfa_enabled")
  mfaSecret         String?     @db.VarChar(255) @map("mfa_secret")
  status            UserStatus  @default(ACTIVE)
  accessExpiresAt   DateTime?   @map("access_expires_at")
  bankInstitutionId String?     @db.Uuid @map("bank_institution_id")
  createdAt         DateTime    @default(now()) @map("created_at")
  lastLoginAt       DateTime?   @map("last_login_at")
  failedLoginCount  Int         @default(0) @map("failed_login_count")
  lockedUntil       DateTime?   @map("locked_until")

  firm              Firm        @relation(fields: [firmId], references: [id])
  bankInstitution   BankInstitution? @relation(fields: [bankInstitutionId], references: [id])
  refreshTokens     RefreshToken[]
  uploads           Upload[]
  boardReports      BoardReport[]
  assuranceReports  AssuranceReport[]
  auditLogs         AuditLog[]
  resolvedBreaks    ReconciliationBreak[] @relation("ResolvedBreaks")
  acknowledgedBreaches Breach[] @relation("AcknowledgedBreaches")
  closedBreaches    Breach[]    @relation("ClosedBreaches")
  submittedNotifications FcaNotification[] @relation("SubmittedNotifications")
  uploadedLetters   AcknowledgementLetter[]
  auditorFindings   AuditorFinding[] @relation("FindingsCreated")
  findingResponses  AuditorFinding[] @relation("FindingResponses")
  alertSettings     AlertSetting[]
  emailLogs         EmailLog[]
  uploadedPolicies  PolicyDocument[]

  @@map("users")
}

model RefreshToken {
  id          String    @id @default(uuid()) @db.Uuid
  userId      String    @db.Uuid @map("user_id")
  token       String    @unique @db.VarChar(500)
  expiresAt   DateTime  @map("expires_at")
  revokedAt   DateTime? @map("revoked_at")
  createdAt   DateTime  @default(now()) @map("created_at")

  user        User      @relation(fields: [userId], references: [id])

  @@map("refresh_tokens")
}

model ClientAccount {
  id          String              @id @default(uuid()) @db.Uuid
  firmId      String              @db.Uuid @map("firm_id")
  clientId    String              @db.VarChar(100) @map("client_id")
  clientName  String?             @db.VarChar(255) @map("client_name")
  fundType    FundType            @default(ALL) @map("fund_type")
  status      ClientAccountStatus @default(ACTIVE)
  createdAt   DateTime            @default(now()) @map("created_at")
  updatedAt   DateTime            @updatedAt @map("updated_at")

  firm        Firm                @relation(fields: [firmId], references: [id])
  balances    ClientBalance[]
  transactions ClientTransaction[]

  @@unique([firmId, clientId])
  @@map("client_accounts")
}

model ClientBalance {
  id                String    @id @default(uuid()) @db.Uuid
  firmId            String    @db.Uuid @map("firm_id")
  clientAccountId   String    @db.Uuid @map("client_account_id")
  currency          String    @db.Char(3)
  balance           Decimal   @db.Decimal(18, 2)
  balanceDate       DateTime  @db.Date @map("balance_date")
  uploadId          String    @db.Uuid @map("upload_id")
  createdAt         DateTime  @default(now()) @map("created_at")

  firm              Firm      @relation(fields: [firmId], references: [id])
  clientAccount     ClientAccount @relation(fields: [clientAccountId], references: [id])
  upload            Upload    @relation(fields: [uploadId], references: [id])

  @@unique([firmId, clientAccountId, currency, balanceDate])
  @@index([firmId, balanceDate])
  @@index([firmId, clientAccountId, currency, balanceDate])
  @@map("client_balances")
}

model ClientTransaction {
  id                    String              @id @default(uuid()) @db.Uuid
  firmId                String              @db.Uuid @map("firm_id")
  clientAccountId       String              @db.Uuid @map("client_account_id")
  externalTransactionId String              @db.VarChar(100) @map("external_transaction_id")
  amount                Decimal             @db.Decimal(18, 2)
  currency              String              @db.Char(3)
  direction             TransactionDirection
  transactionDate       DateTime            @db.Date @map("transaction_date")
  valueDate             DateTime?           @db.Date @map("value_date")
  description           String?             @db.VarChar(500)
  uploadId              String              @db.Uuid @map("upload_id")
  createdAt             DateTime            @default(now()) @map("created_at")

  firm                  Firm                @relation(fields: [firmId], references: [id])
  clientAccount         ClientAccount       @relation(fields: [clientAccountId], references: [id])
  upload                Upload              @relation(fields: [uploadId], references: [id])

  @@map("client_transactions")
}

model SafeguardingAccount {
  id                    String                    @id @default(uuid()) @db.Uuid
  firmId                String                    @db.Uuid @map("firm_id")
  externalAccountId     String                    @db.VarChar(100) @map("external_account_id")
  bankName              String                    @db.VarChar(255) @map("bank_name")
  accountNumberMasked   String                    @db.VarChar(34) @map("account_number_masked")
  sortCode              String?                   @db.VarChar(8) @map("sort_code")
  currency              String                    @db.Char(3)
  fundType              FundType                  @default(ALL) @map("fund_type")
  designation           SafeguardingDesignation
  status                SafeguardingAccountStatus
  openedDate            DateTime                  @db.Date @map("opened_date")
  letterStatus          LetterStatus              @default(PENDING) @map("letter_status")
  createdAt             DateTime                  @default(now()) @map("created_at")
  updatedAt             DateTime                  @updatedAt @map("updated_at")

  firm                  Firm                      @relation(fields: [firmId], references: [id])
  ledgerBalances        SafeguardingLedgerBalance[]
  bankBalances          BankBalance[]
  bankTransactions      BankTransaction[]
  reconciliationBreaks  ReconciliationBreak[]
  acknowledgementLetters AcknowledgementLetter[]
  thirdPartyDueDiligence ThirdPartyDueDiligence[]

  @@unique([firmId, externalAccountId])
  @@map("safeguarding_accounts")
}

model SafeguardingLedgerBalance {
  id                      String              @id @default(uuid()) @db.Uuid
  firmId                  String              @db.Uuid @map("firm_id")
  safeguardingAccountId   String              @db.Uuid @map("safeguarding_account_id")
  currency                String              @db.Char(3)
  balance                 Decimal             @db.Decimal(18, 2)
  balanceDate             DateTime            @db.Date @map("balance_date")
  includesPrudentBuffer   Boolean             @default(false) @map("includes_prudent_buffer")
  prudentBufferAmount     Decimal?            @db.Decimal(18, 2) @map("prudent_buffer_amount")
  uploadId                String              @db.Uuid @map("upload_id")
  createdAt               DateTime            @default(now()) @map("created_at")

  firm                    Firm                @relation(fields: [firmId], references: [id])
  safeguardingAccount     SafeguardingAccount @relation(fields: [safeguardingAccountId], references: [id])
  upload                  Upload              @relation(fields: [uploadId], references: [id])

  @@index([firmId, safeguardingAccountId, balanceDate])
  @@map("safeguarding_ledger_balances")
}

model BankBalance {
  id                    String              @id @default(uuid()) @db.Uuid
  firmId                String              @db.Uuid @map("firm_id")
  safeguardingAccountId String              @db.Uuid @map("safeguarding_account_id")
  currency              String              @db.Char(3)
  closingBalance        Decimal             @db.Decimal(18, 2) @map("closing_balance")
  balanceDate           DateTime            @db.Date @map("balance_date")
  statementReference    String?             @db.VarChar(255) @map("statement_reference")
  uploadId              String              @db.Uuid @map("upload_id")
  createdAt             DateTime            @default(now()) @map("created_at")

  firm                  Firm                @relation(fields: [firmId], references: [id])
  safeguardingAccount   SafeguardingAccount @relation(fields: [safeguardingAccountId], references: [id])
  upload                Upload              @relation(fields: [uploadId], references: [id])

  @@index([firmId, safeguardingAccountId, balanceDate])
  @@map("bank_balances")
}

model BankTransaction {
  id                    String              @id @default(uuid()) @db.Uuid
  firmId                String              @db.Uuid @map("firm_id")
  safeguardingAccountId String              @db.Uuid @map("safeguarding_account_id")
  externalTransactionId String              @db.VarChar(100) @map("external_transaction_id")
  amount                Decimal             @db.Decimal(18, 2)
  currency              String              @db.Char(3)
  direction             TransactionDirection
  transactionDate       DateTime            @db.Date @map("transaction_date")
  counterparty          String?             @db.VarChar(255)
  reference             String?             @db.VarChar(255)
  uploadId              String              @db.Uuid @map("upload_id")
  createdAt             DateTime            @default(now()) @map("created_at")

  firm                  Firm                @relation(fields: [firmId], references: [id])
  safeguardingAccount   SafeguardingAccount @relation(fields: [safeguardingAccountId], references: [id])
  upload                Upload              @relation(fields: [uploadId], references: [id])

  @@map("bank_transactions")
}

model Upload {
  id                String      @id @default(uuid()) @db.Uuid
  firmId            String      @db.Uuid @map("firm_id")
  userId            String      @db.Uuid @map("user_id")
  inputType         InputType   @map("input_type")
  filename          String      @db.VarChar(255)
  fileHash          String      @db.VarChar(64) @map("file_hash")
  fileSizeBytes     Int         @map("file_size_bytes")
  rowCount          Int         @default(0) @map("row_count")
  rowsAccepted      Int         @default(0) @map("rows_accepted")
  rowsRejected      Int         @default(0) @map("rows_rejected")
  status            UploadStatus @default(PENDING)
  errorSummary      Json?       @map("error_summary")
  mappingConfigId   String?     @db.Uuid @map("mapping_config_id")
  storagePath       String?     @db.VarChar(500) @map("storage_path")
  createdAt         DateTime    @default(now()) @map("created_at")

  firm              Firm        @relation(fields: [firmId], references: [id])
  user              User        @relation(fields: [userId], references: [id])
  mappingConfig     MappingConfig? @relation(fields: [mappingConfigId], references: [id])
  clientBalances    ClientBalance[]
  clientTransactions ClientTransaction[]
  ledgerBalances    SafeguardingLedgerBalance[]
  bankBalances      BankBalance[]
  bankTransactions  BankTransaction[]

  @@index([firmId, inputType, createdAt])
  @@map("uploads")
}

model MappingConfig {
  id              String    @id @default(uuid()) @db.Uuid
  firmId          String    @db.Uuid @map("firm_id")
  inputType       InputType @map("input_type")
  columnMappings  Json      @map("column_mappings")
  hasHeaderRow    Boolean   @default(true) @map("has_header_row")
  createdAt       DateTime  @default(now()) @map("created_at")
  updatedAt       DateTime  @updatedAt @map("updated_at")

  firm            Firm      @relation(fields: [firmId], references: [id])
  uploads         Upload[]

  @@unique([firmId, inputType])
  @@map("mapping_configs")
}

model ReconciliationRun {
  id                  String                @id @default(uuid()) @db.Uuid
  firmId              String                @db.Uuid @map("firm_id")
  reconciliationDate  DateTime              @db.Date @map("reconciliation_date")
  reconciliationType  ReconciliationType    @map("reconciliation_type")
  fundType            FundType              @map("fund_type")
  currency            String                @db.Char(3)
  totalRequirement    Decimal               @db.Decimal(18, 2) @map("total_requirement")
  totalResource       Decimal               @db.Decimal(18, 2) @map("total_resource")
  variance            Decimal               @db.Decimal(18, 2)
  variancePercentage  Decimal               @db.Decimal(8, 4) @map("variance_percentage")
  status              ReconciliationStatus
  rulePackId          String                @db.Uuid @map("rule_pack_id")
  trigger             ReconciliationTrigger
  dataCompleteness    DataCompleteness      @map("data_completeness")
  startedAt           DateTime              @map("started_at")
  completedAt         DateTime?             @map("completed_at")
  createdAt           DateTime              @default(now()) @map("created_at")

  firm                Firm                  @relation(fields: [firmId], references: [id])
  rulePack            RulePack              @relation(fields: [rulePackId], references: [id])
  breaks              ReconciliationBreak[]
  breaches            Breach[]

  @@index([firmId, reconciliationDate, reconciliationType])
  @@map("reconciliation_runs")
}

model ReconciliationBreak {
  id                    String              @id @default(uuid()) @db.Uuid
  firmId                String              @db.Uuid @map("firm_id")
  reconciliationRunId   String              @db.Uuid @map("reconciliation_run_id")
  safeguardingAccountId String              @db.Uuid @map("safeguarding_account_id")
  internalBalance       Decimal             @db.Decimal(18, 2) @map("internal_balance")
  externalBalance       Decimal             @db.Decimal(18, 2) @map("external_balance")
  variance              Decimal             @db.Decimal(18, 2)
  classification        BreakClassification @default(UNRESOLVED)
  explanation           String?             @db.Text
  resolvedAt            DateTime?           @map("resolved_at")
  resolvedBy            String?             @db.Uuid @map("resolved_by")
  firstDetectedDate     DateTime            @db.Date @map("first_detected_date")
  ageBusinessDays       Int                 @default(0) @map("age_business_days")
  createdAt             DateTime            @default(now()) @map("created_at")
  updatedAt             DateTime            @updatedAt @map("updated_at")

  firm                  Firm                @relation(fields: [firmId], references: [id])
  reconciliationRun     ReconciliationRun   @relation(fields: [reconciliationRunId], references: [id])
  safeguardingAccount   SafeguardingAccount @relation(fields: [safeguardingAccountId], references: [id])
  resolver              User?               @relation("ResolvedBreaks", fields: [resolvedBy], references: [id])

  @@map("reconciliation_breaks")
}

model Breach {
  id                        String        @id @default(uuid()) @db.Uuid
  firmId                    String        @db.Uuid @map("firm_id")
  reconciliationRunId       String?       @db.Uuid @map("reconciliation_run_id")
  breachType                BreachType    @map("breach_type")
  severity                  BreachSeverity
  isNotifiable              Boolean       @default(false) @map("is_notifiable")
  materialDiscrepancyExceeded Boolean     @default(false) @map("material_discrepancy_exceeded")
  currency                  String?       @db.Char(3)
