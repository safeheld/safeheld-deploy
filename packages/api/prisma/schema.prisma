  firmId                String                @db.Uuid @map("firm_id")
  snapshotDate          DateTime              @db.Date @map("snapshot_date")
  totalReservesUsd      Decimal               @db.Decimal(18, 2) @map("total_reserves_usd")
  totalEntitlementsUsd  Decimal               @db.Decimal(18, 2) @map("total_entitlements_usd")
  reserveRatio          Decimal               @db.Decimal(8, 4) @map("reserve_ratio")
  status                ProofOfReservesStatus @default(PENDING)
  tokenBreakdown        Json                  @map("token_breakdown")
  walletBreakdown       Json                  @map("wallet_breakdown")
  attestationHash       String?               @db.VarChar(128) @map("attestation_hash")
  generatedBy           String?               @db.Uuid @map("generated_by")
  verifiedAt            DateTime?             @map("verified_at")
  createdAt             DateTime              @default(now()) @map("created_at")

  firm                  Firm                  @relation(fields: [firmId], references: [id])

  @@index([firmId, snapshotDate])
  @@map("proof_of_reserves")
}

model DataLineageEvent {
  id                    String                @id @default(uuid()) @db.Uuid
  firmId                String                @db.Uuid @map("firm_id")
  eventType             DataLineageEventType  @map("event_type")
  sourceSystem          String                @db.VarChar(255) @map("source_system")
  entityType            String                @db.VarChar(100) @map("entity_type")
  entityId              String?               @db.Uuid @map("entity_id")
  recordCount           Int?                  @map("record_count")
  dataHash              String?               @db.VarChar(128) @map("data_hash")
  metadata              Json?
  parentEventId         String?               @db.Uuid @map("parent_event_id")
  createdAt             DateTime              @default(now()) @map("created_at")

  firm                  Firm                  @relation(fields: [firmId], references: [id])

  @@index([firmId, eventType, createdAt])
  @@index([entityType, entityId])
  @@map("data_lineage_events")
}
