# ─────────────────────────────────────────────────────────────────────────────
#  Safeheld — Environment Variables
#
#  Copy this file to .env and fill in every value marked CHANGE_ME.
#  Never commit your real .env file to version control.
# ─────────────────────────────────────────────────────────────────────────────

# ── Application ───────────────────────────────────────────────────────────────
NODE_ENV=production
LOG_LEVEL=info
PORT=3001

# Public URL of the frontend (used for CORS and email links)
FRONTEND_URL=http://YOUR_SERVER_IP_OR_DOMAIN

# ── PostgreSQL ────────────────────────────────────────────────────────────────
# docker-compose reads these to configure the postgres container AND build
# the DATABASE_URL that the api container uses internally.
POSTGRES_USER=safeheld
POSTGRES_PASSWORD=CHANGE_ME_strong_db_password
POSTGRES_DB=safeheld

# ── Redis ─────────────────────────────────────────────────────────────────────
# Leave blank if you do not want Redis auth (acceptable for single-host deploys).
# REDIS_PASSWORD=CHANGE_ME_redis_password

# ── MinIO (S3-compatible object storage) ──────────────────────────────────────
# These are also used as S3_ACCESS_KEY / S3_SECRET_KEY inside docker-compose.
MINIO_ROOT_USER=safeheld_minio
MINIO_ROOT_PASSWORD=CHANGE_ME_minio_password

# Bucket names — change only if you renamed them in minio-init
S3_BUCKET=safeheld-uploads
S3_REPORTS_BUCKET=safeheld-reports
S3_DOCUMENTS_BUCKET=safeheld-documents

# ── JWT (generate with: openssl rand -hex 32) ────────────────────────────────
JWT_SECRET=CHANGE_ME_at_least_32_random_characters_here
JWT_REFRESH_SECRET=CHANGE_ME_another_32_random_characters
JWT_EXPIRES_IN=15m
JWT_REFRESH_EXPIRES_IN=24h

# ── MFA (must be exactly 32 characters) ───────────────────────────────────────
MFA_ENCRYPTION_KEY=CHANGE_ME_exactly_32_chars_here!

# ── Session ───────────────────────────────────────────────────────────────────
SESSION_SECRET=CHANGE_ME_session_secret_min_32_chars_here

# ── SMTP / Email ──────────────────────────────────────────────────────────────
# Leave blank to disable email sending (app still works, just no emails).
SMTP_HOST=smtp.postmarkapp.com
SMTP_PORT=587
SMTP_USER=
SMTP_PASSWORD=
SMTP_FROM_EMAIL=noreply@yourdomain.com
SMTP_FROM_NAME=Safeheld

# ── Security ──────────────────────────────────────────────────────────────────
BCRYPT_ROUNDS=12

# ── Admin seed account ────────────────────────────────────────────────────────
# Created when you run: docker compose exec api npm run seed
ADMIN_EMAIL=admin@yourdomain.com
ADMIN_PASSWORD=CHANGE_ME_strong_admin_password

# ── Pagination ────────────────────────────────────────────────────────────────
DEFAULT_PAGE_SIZE=50
MAX_PAGE_SIZE=200

# ── Rate Limiting (requests per window) ───────────────────────────────────────
RATE_LIMIT_AUTH=10
RATE_LIMIT_UPLOAD=20
RATE_LIMIT_GENERAL=100
