{
  "name": "safeheld",
  "version": "1.0.0",
  "private": true,
  "workspaces": [
    "packages/api",
    "packages/web"
  ],
  "scripts": {
    "dev": "concurrently \"npm run dev --workspace=packages/api\" \"npm run dev --workspace=packages/web\"",
    "build": "npm run build --workspace=packages/api && npm run build --workspace=packages/web",
    "test": "npm run test --workspace=packages/api",
    "migrate": "npm run migrate --workspace=packages/api",
    "seed": "npm run seed --workspace=packages/api"
  },
  "devDependencies": {
    "concurrently": "^8.2.2"
  }
}
